# Entorno
exec_always export XDG_CURRENT_DESKTOP=sway
exec_always systemctl --user set-environment XDG_CURRENT_DESKTOP=sway
exec_always systemctl --user import-environment DISPLAY WAYLAND_DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP

# Portals (importante)
exec_always systemctl --user start xdg-desktop-portal-wlr.service

# Notificaciones
exec_always mako

# Terminal inicial
exec_always $term

# Opcionales (comentados)
# exec syncthing
exec_always export QT_QPA_PLATFORMTHEME=qt6ct
